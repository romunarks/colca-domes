---
import Layout from "../../layouts/Layout.astro";
import { getSupabaseAdmin } from "../../lib/server/supabase";
import { listRecentBookingLeads, listUpcomingReservations, type BookingLeadRow, type ReservationRow } from "../../lib/server/booking";
import { requireAdminAuth } from "../../lib/server/adminAuth";

const queryLang = Astro.url.searchParams.get("lang");
const lang = Astro.url.pathname.startsWith("/en/") || queryLang === "en" ? "en" : "es";
const copy =
  lang === "en"
    ? {
        title: "Admin Dashboard | Colca Star Domes",
        description: "Internal dashboard for leads and reservations.",
        eyebrow: "Admin dashboard",
        heading: "Pre-booking leads",
        subtitle: "This view shows leads stored in database before opening WhatsApp.",
        backToLanding: "Back to landing",
        dataErrorTitle: "Could not load data",
        totalLeads: "Total leads",
        newLeads: "New",
        contactedLeads: "Contacted",
        closedLeads: "Closed",
        activeReservations: "Active reservations",
        confirmedReservations: "Confirmed",
        pendingReservations: "Pending",
        thDate: "Date",
        thLead: "Lead",
        thStay: "Stay",
        thGuests: "Guests",
        thStatus: "Status",
        thEstimate: "Estimate",
        thNotes: "Notes",
        thActions: "Actions",
        noLeads: "No leads yet.",
        whatsappCta: "WhatsApp",
        domes: "Domes",
        status: "Status",
        createReservation: "Convert to reservation",
        reservationsTitle: "Reservations (pending/confirmed)",
        refresh: "Refresh",
        reservationsErrorPrefix: "Could not load reservations",
        reservationsErrorHint: "Run the latest `supabase/schema.sql` (adds `reservations.lead_id`).",
        rCheckIn: "Check-in",
        rCheckOut: "Check-out",
        rAssigned: "Assigned",
        rLead: "Lead",
        noReservations: "No active reservations yet.",
        assignDomes: "Assign domes",
        cancel: "Cancel",
        delete: "Delete",
        alertStatusUpdateFail: "Could not update lead status.",
        alertRefreshFail: "Could not refresh reservations.",
        promptAssignDomes: "Enter dome codes separated by commas.\nAvailable: {codes}\n\nExample: DOME-01,DOME-03",
        alertAssignFail: "Could not assign domes.",
        alertAssignedOk: "Domes assigned.",
        confirmCancel: "Cancel this reservation?",
        alertCancelFail: "Could not cancel reservation.",
        confirmDelete: "DELETE this reservation permanently?",
        alertDeleteFail: "Could not delete reservation.",
        alertCreateFail: "Could not create reservation.",
        alertCreateOk: "Reservation created.",
        waLeadTemplate:
          "Hi, this is Colca Star Domes. We confirm your request.\nLead: {leadId}\nCheck-in: {checkIn}\nCheck-out: {checkOut}\nGuests: {guests}",
        refreshAssignCta: "Assign domes",
        refreshCancelCta: "Cancel",
        refreshDeleteCta: "Delete",
      }
    : {
        title: "Admin Leads | Colca Star Domes",
        description: "Vista interna de pre-reservas registradas desde la web.",
        eyebrow: "Admin dashboard",
        heading: "Leads de pre-reserva",
        subtitle: "Esta vista muestra los leads guardados en base de datos antes de abrir WhatsApp.",
        backToLanding: "Volver a la landing",
        dataErrorTitle: "No se pudo cargar la data",
        totalLeads: "Total leads",
        newLeads: "Nuevos",
        contactedLeads: "Contactados",
        closedLeads: "Cerrados",
        activeReservations: "Reservas activas",
        confirmedReservations: "Confirmadas",
        pendingReservations: "Pendientes",
        thDate: "Fecha",
        thLead: "Lead",
        thStay: "Estadia",
        thGuests: "Huespedes",
        thStatus: "Estado",
        thEstimate: "Estimado",
        thNotes: "Notas",
        thActions: "Acciones",
        noLeads: "Aun no hay leads registrados.",
        whatsappCta: "WhatsApp",
        domes: "Domos",
        status: "Estado",
        createReservation: "Convertir a reserva",
        reservationsTitle: "Reservas (pendientes/confirmadas)",
        refresh: "Refrescar",
        reservationsErrorPrefix: "No se pudieron cargar reservas",
        reservationsErrorHint: "Ejecuta el `supabase/schema.sql` actualizado (añade `reservations.lead_id`).",
        rCheckIn: "Check-in",
        rCheckOut: "Check-out",
        rAssigned: "Asignados",
        rLead: "Lead",
        noReservations: "Aun no hay reservas activas.",
        assignDomes: "Asignar domos",
        cancel: "Cancelar",
        delete: "Borrar",
        alertStatusUpdateFail: "No se pudo actualizar el estado.",
        alertRefreshFail: "No se pudo refrescar reservas.",
        promptAssignDomes: "Escribe los codigos de domo separados por coma.\nDisponibles: {codes}\n\nEj: DOME-01,DOME-03",
        alertAssignFail: "No se pudo asignar domos.",
        alertAssignedOk: "Domos asignados.",
        confirmCancel: "Cancelar esta reserva?",
        alertCancelFail: "No se pudo cancelar.",
        confirmDelete: "BORRAR esta reserva definitivamente?",
        alertDeleteFail: "No se pudo borrar.",
        alertCreateFail: "No se pudo crear la reserva.",
        alertCreateOk: "Reserva creada.",
        waLeadTemplate:
          "Hola, soy de Colca Star Domes. Confirmamos tu solicitud.\nLead: {leadId}\nCheck-in: {checkIn}\nCheck-out: {checkOut}\nHuespedes: {guests}",
        refreshAssignCta: "Asignar domos",
        refreshCancelCta: "Cancelar",
        refreshDeleteCta: "Borrar",
      };

const adminLangHref = lang === "en" ? "/admin/leads?lang=es" : "/admin/leads?lang=en";
const adminLangLabel = lang === "en" ? "Ver admin en Espanol" : "View admin in English";

const auth = requireAdminAuth(Astro.request);
if (!auth.ok) return auth.response;

let leads: BookingLeadRow[] = [];
let reservations: ReservationRow[] = [];
let loadError = "";
let reservationsError = "";
let supabase: ReturnType<typeof getSupabaseAdmin> | null = null;

try {
  supabase = getSupabaseAdmin();
  leads = await listRecentBookingLeads(supabase, 100);
} catch (error) {
  loadError = error instanceof Error ? error.message : "No se pudo cargar la lista de leads.";
}

if (supabase) {
  try {
    reservations = await listUpcomingReservations(supabase, 150);
  } catch (error) {
    reservationsError = error instanceof Error ? error.message : "No se pudieron cargar las reservas.";
    reservations = [];
  }
} else {
  reservationsError = "No se pudo inicializar la conexion de base de datos.";
}

const totals = {
  all: leads.length,
  new: leads.filter((lead) => lead.status === "new").length,
  contacted: leads.filter((lead) => lead.status === "contacted").length,
  closed: leads.filter((lead) => lead.status === "closed").length,
};

const reservationTotals = {
  all: reservations.length,
  confirmed: reservations.filter((r) => r.status === "confirmed").length,
  pending: reservations.filter((r) => r.status === "pending").length,
};

const formatDateTime = (value: string) =>
  new Date(value).toLocaleString("es-PE", {
    dateStyle: "medium",
    timeStyle: "short",
  });

const whatsappNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "").trim() || "51999999999";
---

<Layout title={copy.title} description={copy.description}>
  <section class="mx-auto w-full max-w-7xl px-4 pb-14 pt-24 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-gold">{copy.eyebrow}</p>
        <h1 class="mt-2 text-3xl font-semibold text-sillar">{copy.heading}</h1>
        <p class="mt-2 text-sm text-slate-300">
          {copy.subtitle}
        </p>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row">
        <a
          href={adminLangHref}
          class="inline-flex items-center justify-center rounded-full bg-gold px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-amber-300"
        >
          {adminLangLabel}
        </a>
        <a
          href={lang === "en" ? "/en" : "/"}
          class="inline-flex items-center justify-center rounded-full border border-gold px-4 py-2 text-sm font-medium text-gold transition hover:bg-gold/10"
        >
          {copy.backToLanding}
        </a>
      </div>
    </div>

    {
      loadError && (
        <div class="rounded-2xl border border-rose-500/40 bg-rose-500/10 p-5 text-rose-100">
          <p class="text-sm font-medium">{copy.dataErrorTitle}</p>
          <p class="mt-2 text-sm">{loadError}</p>
        </div>
      )
    }

    {
      !loadError && (
        <>
          <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
              <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{copy.totalLeads}</p>
              <p class="mt-2 text-2xl font-semibold text-sillar">{totals.all}</p>
            </article>
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
              <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{copy.newLeads}</p>
              <p class="mt-2 text-2xl font-semibold text-amber-300">{totals.new}</p>
            </article>
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
              <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{copy.contactedLeads}</p>
              <p class="mt-2 text-2xl font-semibold text-sky-300">{totals.contacted}</p>
            </article>
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
              <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{copy.closedLeads}</p>
              <p class="mt-2 text-2xl font-semibold text-emerald-300">{totals.closed}</p>
            </article>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-4 md:grid-cols-3">
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
              <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{copy.activeReservations}</p>
              <p class="mt-2 text-2xl font-semibold text-sillar">{reservationTotals.all}</p>
            </article>
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
              <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{copy.confirmedReservations}</p>
              <p class="mt-2 text-2xl font-semibold text-emerald-300">{reservationTotals.confirmed}</p>
            </article>
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
              <p class="text-xs uppercase tracking-[0.15em] text-slate-400">{copy.pendingReservations}</p>
              <p class="mt-2 text-2xl font-semibold text-amber-300">{reservationTotals.pending}</p>
            </article>
          </div>

          <div class="mt-6 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60">
            <div class="overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-slate-950/70 text-xs uppercase tracking-[0.12em] text-slate-400">
                  <tr>
                    <th class="px-4 py-3">{copy.thDate}</th>
                    <th class="px-4 py-3">{copy.thLead}</th>
                    <th class="px-4 py-3">{copy.thStay}</th>
                    <th class="px-4 py-3">{copy.thGuests}</th>
                    <th class="px-4 py-3">{copy.thStatus}</th>
                    <th class="px-4 py-3">{copy.thEstimate}</th>
                    <th class="px-4 py-3">{copy.thNotes}</th>
                    <th class="px-4 py-3">{copy.thActions}</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                  {
                    leads.length === 0 ? (
                      <tr>
                        <td colspan="8" class="px-4 py-6 text-center text-slate-300">
                          {copy.noLeads}
                        </td>
                      </tr>
                    ) : (
                      leads.map((lead) => (
                        <tr class="align-top text-slate-100">
                          <td class="px-4 py-3 text-xs text-slate-300">{formatDateTime(lead.created_at)}</td>
                          <td class="px-4 py-3">
                            <p class="font-medium">{lead.full_name}</p>
                            <p class="text-xs text-slate-400">{lead.id}</p>
                          </td>
                          <td class="px-4 py-3 text-xs sm:text-sm">
                            {lead.check_in} → {lead.check_out}
                          </td>
                          <td class="px-4 py-3">{lead.guests}</td>
                          <td class="px-4 py-3">
                            <select
                              class="rounded-xl border border-slate-700 bg-slate-950/60 px-2 py-1 text-xs text-slate-100"
                              data-lead-status
                              data-lead-id={lead.id}
                              aria-label={`Estado lead ${lead.id}`}
                            >
                              <option value="new" selected={lead.status === "new"}>new</option>
                              <option value="contacted" selected={lead.status === "contacted"}>contacted</option>
                              <option value="qualified" selected={lead.status === "qualified"}>qualified</option>
                              <option value="closed" selected={lead.status === "closed"}>closed</option>
                            </select>
                          </td>
                          <td class="px-4 py-3 text-xs sm:text-sm">
                            {typeof lead.availability_snapshot?.totalEstimate === "number"
                              ? `S/ ${lead.availability_snapshot.totalEstimate}`
                              : "-"}
                          </td>
                          <td class="px-4 py-3 text-xs text-slate-300">{lead.notes ?? "-"}</td>
                          <td class="px-4 py-3">
                            <div class="flex flex-wrap gap-2">
                              <a
                                class="inline-flex items-center justify-center rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-200 transition hover:bg-slate-800/60"
                                href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(
                                  copy.waLeadTemplate
                                    .replace("{leadId}", lead.id)
                                    .replace("{checkIn}", lead.check_in)
                                    .replace("{checkOut}", lead.check_out)
                                    .replace("{guests}", String(lead.guests))
                                )}`}
                                target="_blank"
                                rel="noopener noreferrer"
                              >
                                WhatsApp
                              </a>
                              <div class="flex items-center gap-2 rounded-full border border-slate-800 bg-slate-950/40 px-3 py-1">
                                <label class="text-[11px] text-slate-400">
                                  {copy.domes}
                                  <input
                                    type="number"
                                    min="1"
                                    max="20"
                                    value="1"
                                    class="ml-2 w-14 rounded-lg border border-slate-700 bg-slate-950/60 px-2 py-1 text-xs text-slate-100"
                                    data-res-domes
                                    data-lead-id={lead.id}
                                  />
                                </label>
                                <label class="text-[11px] text-slate-400">
                                  {copy.status}
                                  <select
                                    class="ml-2 rounded-lg border border-slate-700 bg-slate-950/60 px-2 py-1 text-xs text-slate-100"
                                    data-res-status
                                    data-lead-id={lead.id}
                                  >
                                    <option value="pending">pending</option>
                                    <option value="confirmed" selected>confirmed</option>
                                  </select>
                                </label>
                              </div>
                              <button
                                type="button"
                                class="inline-flex items-center justify-center rounded-full border border-gold px-3 py-1 text-xs font-medium text-gold transition hover:bg-gold/10"
                                data-create-reservation
                                data-lead-id={lead.id}
                              >
                                {copy.createReservation}
                              </button>
                            </div>
                          </td>
                        </tr>
                      ))
                    )
                  }
                </tbody>
              </table>
            </div>
          </div>

          <div class="mt-8 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60">
            <div class="flex items-center justify-between gap-4 border-b border-slate-800 bg-slate-950/40 px-4 py-3">
              <p class="text-xs uppercase tracking-[0.12em] text-slate-400">{copy.reservationsTitle}</p>
              <button
                type="button"
                class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-200 transition hover:bg-slate-800/60"
                data-refresh-reservations
              >
                {copy.refresh}
              </button>
            </div>
            {reservationsError && (
              <div class="border-b border-slate-800 px-4 py-3 text-xs text-amber-200">
                {copy.reservationsErrorPrefix}: {reservationsError}. {copy.reservationsErrorHint}
              </div>
            )}
            <div class="overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-slate-950/70 text-xs uppercase tracking-[0.12em] text-slate-400">
                  <tr>
                    <th class="px-4 py-3">{copy.rCheckIn}</th>
                    <th class="px-4 py-3">{copy.rCheckOut}</th>
                    <th class="px-4 py-3">{copy.domes}</th>
                    <th class="px-4 py-3">{copy.rAssigned}</th>
                    <th class="px-4 py-3">{copy.thStatus}</th>
                    <th class="px-4 py-3">{copy.rLead}</th>
                    <th class="px-4 py-3">{copy.thActions}</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-800" id="reservations-body">
                  {
                    reservations.length === 0 ? (
                      <tr>
                        <td colspan="7" class="px-4 py-6 text-center text-slate-300">
                          {copy.noReservations}
                        </td>
                      </tr>
                    ) : (
                      reservations.map((r) => (
                        <tr class="text-slate-100">
                          <td class="px-4 py-3 text-xs sm:text-sm">{r.check_in}</td>
                          <td class="px-4 py-3 text-xs sm:text-sm">{r.check_out}</td>
                          <td class="px-4 py-3">{r.domes_booked}</td>
                          <td class="px-4 py-3 text-xs text-slate-300">-</td>
                          <td class="px-4 py-3">
                            <span class="rounded-full border border-slate-700 px-2 py-1 text-xs capitalize text-slate-200">
                              {r.status}
                            </span>
                          </td>
                          <td class="px-4 py-3 text-xs text-slate-400">{r.lead_id ?? "-"}</td>
                          <td class="px-4 py-3">
                            <div class="flex flex-wrap gap-2">
                              <button
                                type="button"
                                class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-200 transition hover:bg-slate-800/60"
                                data-assign-domes
                                data-reservation-id={r.id}
                              >
                                {copy.assignDomes}
                              </button>
                              <button
                                type="button"
                                class="rounded-full border border-amber-400/60 px-3 py-1 text-xs text-amber-200 transition hover:bg-amber-400/10"
                                data-cancel-reservation
                                data-reservation-id={r.id}
                              >
                                {copy.cancel}
                              </button>
                              <button
                                type="button"
                                class="rounded-full border border-rose-500/50 px-3 py-1 text-xs text-rose-200 transition hover:bg-rose-500/10"
                                data-delete-reservation
                                data-reservation-id={r.id}
                              >
                                {copy.delete}
                              </button>
                            </div>
                          </td>
                        </tr>
                      ))
                    )
                  }
                </tbody>
              </table>
            </div>
          </div>
        </>
      )
    }
  </section>
</Layout>

<script define:vars={{ copy }}>
  const jsonHeaders = { "Content-Type": "application/json" };

  const postJson = async (url, payload) => {
    const response = await fetch(url, {
      method: "POST",
      headers: jsonHeaders,
      body: JSON.stringify(payload),
    });
    const data = await response.json().catch(() => ({}));
    return { ok: response.ok, data };
  };

  document.addEventListener("change", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLSelectElement)) return;
    if (!target.hasAttribute("data-lead-status")) return;

    const leadId = target.getAttribute("data-lead-id") ?? "";
    const status = target.value;
    if (!leadId) return;

    const previous = target.getAttribute("data-prev") ?? "";
    target.setAttribute("data-prev", status);

    const result = await postJson("/api/admin/leads/status", { leadId, status });
    if (!result.ok || !result.data?.ok) {
      if (previous) target.value = previous;
      alert(result.data?.message ?? copy.alertStatusUpdateFail);
    }
  });

  document.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const refresh = target.closest("[data-refresh-reservations]");
    if (refresh instanceof HTMLButtonElement) {
      refresh.disabled = true;
      const response = await fetch("/api/admin/reservations");
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data?.ok) {
        refresh.disabled = false;
        alert(data?.message ?? copy.alertRefreshFail);
        return;
      }

      const body = document.querySelector("#reservations-body");
      if (!(body instanceof HTMLElement)) {
        refresh.disabled = false;
        return;
      }

      const rows = data.reservations ?? [];
      body.innerHTML =
        rows.length === 0
          ? `<tr><td colspan="7" class="px-4 py-6 text-center text-slate-300">${copy.noReservations}</td></tr>`
          : rows
              .map(
                (r) => `<tr class="text-slate-100">
  <td class="px-4 py-3 text-xs sm:text-sm">${r.check_in}</td>
  <td class="px-4 py-3 text-xs sm:text-sm">${r.check_out}</td>
  <td class="px-4 py-3">${r.domes_booked}</td>
  <td class="px-4 py-3 text-xs text-slate-300">${(r.assigned_domes ?? []).join(", ") || "-"}</td>
  <td class="px-4 py-3"><span class="rounded-full border border-slate-700 px-2 py-1 text-xs capitalize text-slate-200">${r.status}</span></td>
  <td class="px-4 py-3 text-xs text-slate-400">${r.lead_id ?? "-"}</td>
  <td class="px-4 py-3">
    <div class="flex flex-wrap gap-2">
      <button type="button" class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-200 transition hover:bg-slate-800/60" data-assign-domes data-reservation-id="${r.id}">${copy.refreshAssignCta}</button>
      <button type="button" class="rounded-full border border-amber-400/60 px-3 py-1 text-xs text-amber-200 transition hover:bg-amber-400/10" data-cancel-reservation data-reservation-id="${r.id}">${copy.refreshCancelCta}</button>
      <button type="button" class="rounded-full border border-rose-500/50 px-3 py-1 text-xs text-rose-200 transition hover:bg-rose-500/10" data-delete-reservation data-reservation-id="${r.id}">${copy.refreshDeleteCta}</button>
    </div>
  </td>
</tr>`
              )
              .join("");

      refresh.disabled = false;
      return;
    }

    const assign = target.closest("[data-assign-domes]");
    if (assign instanceof HTMLButtonElement) {
      const reservationId = assign.getAttribute("data-reservation-id") ?? "";
      if (!reservationId) return;

      const domesRes = await fetch("/api/admin/domes");
      const domesData = await domesRes.json().catch(() => ({}));
      const availableCodes = (domesData.domes ?? []).map((d) => d.code).join(", ");

      const input = prompt(copy.promptAssignDomes.replace("{codes}", availableCodes), "");
      if (input === null) return;
      const domeCodes = input
        .split(",")
        .map((v) => v.trim())
        .filter(Boolean);

      assign.disabled = true;
      const result = await postJson("/api/admin/reservations/assign", { reservationId, domeCodes });
      assign.disabled = false;
      if (!result.ok || !result.data?.ok) {
        alert(result.data?.message ?? copy.alertAssignFail);
        return;
      }

      alert(copy.alertAssignedOk);
      window.location.reload();
      return;
    }

    const cancel = target.closest("[data-cancel-reservation]");
    if (cancel instanceof HTMLButtonElement) {
      const reservationId = cancel.getAttribute("data-reservation-id") ?? "";
      if (!reservationId) return;
      if (!confirm(copy.confirmCancel)) return;
      cancel.disabled = true;
      const result = await postJson("/api/admin/reservations/cancel", { reservationId });
      if (!result.ok || !result.data?.ok) {
        cancel.disabled = false;
        alert(result.data?.message ?? copy.alertCancelFail);
        return;
      }
      window.location.reload();
      return;
    }

    const del = target.closest("[data-delete-reservation]");
    if (del instanceof HTMLButtonElement) {
      const reservationId = del.getAttribute("data-reservation-id") ?? "";
      if (!reservationId) return;
      if (!confirm(copy.confirmDelete)) return;
      del.disabled = true;
      const result = await postJson("/api/admin/reservations/delete", { reservationId });
      if (!result.ok || !result.data?.ok) {
        del.disabled = false;
        alert(result.data?.message ?? copy.alertDeleteFail);
        return;
      }
      window.location.reload();
      return;
    }

    const button = target.closest("[data-create-reservation]");
    if (!(button instanceof HTMLButtonElement)) return;

    const leadId = button.getAttribute("data-lead-id") ?? "";
    if (!leadId) return;

    const domesInput = document.querySelector(`[data-res-domes][data-lead-id="${leadId}"]`);
    const statusSelect = document.querySelector(`[data-res-status][data-lead-id="${leadId}"]`);

    const domesBooked =
      domesInput instanceof HTMLInputElement ? Number(domesInput.value || "1") : 1;
    const status =
      statusSelect instanceof HTMLSelectElement ? statusSelect.value : "confirmed";

    button.disabled = true;
    const result = await postJson("/api/admin/reservations", {
      leadId,
      status,
      domesBooked,
    });

    if (!result.ok || !result.data?.ok) {
      button.disabled = false;
      alert(result.data?.message ?? copy.alertCreateFail);
      return;
    }

    alert(copy.alertCreateOk);
    window.location.reload();
  });
</script>

