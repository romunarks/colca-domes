---
import { getLangFromPath, t } from "../i18n";
const lang = getLangFromPath(Astro.url.pathname);
const tr = t(lang);
const whatsappNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "").trim() || "51999999999";
const defaultWhatsApp = `https://wa.me/${whatsappNumber}`;
---

<section id="prebook" class="mx-auto w-full max-w-5xl scroll-mt-28 px-4 py-16 sm:px-6 md:py-24 lg:px-8">
  <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6 sm:p-8">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-gold sm:text-sm">{tr.prebook.eyebrow}</p>
    <h2 class="mt-3 text-2xl font-semibold text-sillar sm:text-3xl">{tr.prebook.title}</h2>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-300 sm:text-base">
      {tr.prebook.body}
    </p>

    <form id="prebooking-form" class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-2">
        <span class="text-sm text-slate-200">{tr.prebook.name}</span>
        <input
          id="guest-name"
          type="text"
          required
          class="rounded-xl border border-slate-700 bg-slate-950/70 px-4 py-3 text-sm text-sillar outline-none transition focus:border-gold"
          placeholder={tr.prebook.namePlaceholder}
        />
      </label>

      <div class="flex flex-col gap-2 md:col-span-2">
        <span class="text-sm text-slate-200">{tr.prebook.dates}</span>

        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <input
            id="checkin-date"
            type="date"
            required
            class="hidden"
            aria-hidden="true"
            tabindex="-1"
          />
          <input
            id="checkout-date"
            type="date"
            required
            class="hidden"
            aria-hidden="true"
            tabindex="-1"
          />

          <button
            id="date-range-button"
            type="button"
            class="inline-flex items-center justify-between rounded-xl border border-slate-700 bg-slate-950/70 px-4 py-3 text-sm text-sillar outline-none transition focus:border-gold"
          >
            <span id="date-range-label" class="text-left text-slate-200">{tr.prebook.selectRange}</span>
            <span class="text-xs text-slate-400">{tr.prebook.calendar}</span>
          </button>

          <div class="rounded-xl border border-slate-800 bg-slate-950/50 px-4 py-3 text-xs text-slate-300">
            <p class="font-medium text-slate-200">{tr.prebook.tipTitle}</p>
            <p class="mt-1">{tr.prebook.tipBody}</p>
          </div>
        </div>

        <div
          id="calendar-popover"
          class="mt-3 hidden rounded-2xl border border-slate-800 bg-slate-950/90 p-4"
        >
          <div class="mb-3 flex items-center justify-between gap-3">
            <p class="text-xs uppercase tracking-[0.12em] text-slate-400">{tr.prebook.chooseRange}</p>
            <div class="flex items-center gap-2">
              <button
                id="cal-prev"
                type="button"
                class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-200 transition hover:bg-slate-800/60"
              >
                ‹
              </button>
              <button
                id="cal-next"
                type="button"
                class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-200 transition hover:bg-slate-800/60"
              >
                ›
              </button>
              <button
                id="cal-close"
                type="button"
                class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-200 transition hover:bg-slate-800/60"
              >
                {tr.prebook.close}
              </button>
            </div>
          </div>

          <div id="calendar-grid" class="grid grid-cols-1 gap-4 md:grid-cols-2"></div>

          <p class="mt-3 text-xs text-slate-400">
            {tr.prebook.legend} <span class="text-emerald-300">green</span> {tr.prebook.available},{" "}
            <span class="text-rose-300">red</span> {tr.prebook.soldOut}.
          </p>
        </div>
      </div>

      <label class="flex flex-col gap-2">
        <span class="text-sm text-slate-200">{tr.prebook.guests}</span>
        <select
          id="guests"
          class="rounded-xl border border-slate-700 bg-slate-950/70 px-4 py-3 text-sm text-sillar outline-none transition focus:border-gold"
        >
          <option value="1">{tr.prebook.guestLabel.replace("{n}", "1")}</option>
          <option value="2" selected>{tr.prebook.guestLabel.replace("{n}", "2")}</option>
          <option value="3">{tr.prebook.guestLabel.replace("{n}", "3")}</option>
          <option value="4">{tr.prebook.guestLabel.replace("{n}", "4")}</option>
        </select>
      </label>

      <label class="flex flex-col gap-2 md:col-span-2">
        <span class="text-sm text-slate-200">{tr.prebook.notes}</span>
        <textarea
          id="extra-message"
          rows="4"
          class="rounded-xl border border-slate-700 bg-slate-950/70 px-4 py-3 text-sm text-sillar outline-none transition focus:border-gold"
          placeholder={tr.prebook.notesPlaceholder}
        ></textarea>
      </label>

      <div class="md:col-span-2">
        <p id="availability-status" class="mb-4 hidden rounded-xl border px-4 py-3 text-sm"></p>
        <button
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-full bg-gold px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-amber-300 sm:w-auto"
        >
          {tr.prebook.submit}
        </button>
      </div>
    </form>

    <noscript>
      <p class="mt-4 text-sm text-slate-300">
        {tr.prebook.noScript}
        <a href={defaultWhatsApp} target="_blank" rel="noopener noreferrer" class="text-gold underline">
          {tr.prebook.whatsappBooking}
        </a>
      </p>
    </noscript>
  </div>
</section>

<script>
  const whatsappNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "").trim() || "51999999999";
  const lang = window.location.pathname.startsWith("/en") ? "en" : "es";
  const i18n = lang === "en"
    ? {
        weekdays: ["M", "T", "W", "T", "F", "S", "S"],
        locale: "en-US",
        selectRange: "Select check-in and check-out",
        fill: "Please complete name, dates, and number of guests.",
        checking: "Checking availability...",
        validating: "Validating dates and availability...",
        noValidate: "Could not validate availability.",
        noStock: "No availability for those dates. Message us on WhatsApp for alternatives.",
        available: (domes: number, total: number, nights: number) =>
          `Available: ${domes} dome(s). Estimate: PEN ${total} for ${nights} night(s).`,
        leadFail: "Availability found, but we couldn't save the pre-booking. Please try again.",
        generic: "We couldn't process your request right now. Please try again in a few minutes.",
        submit: "Check availability and send via WhatsApp",
        waIntro: "Hi Colca Star Domes, I'd like to make a pre-booking.",
        waName: "Name",
        waGuests: "Guests",
        waConfirmed: "Confirmed availability",
        waEstimate: "Total estimate",
        waCode: "Internal pre-booking code",
        waExtra: "Additional message",
      }
    : {
        weekdays: ["L", "M", "M", "J", "V", "S", "D"],
        locale: "es-PE",
        selectRange: "Selecciona check-in y check-out",
        fill: "Completa nombre, fechas y cantidad de huéspedes.",
        checking: "Consultando disponibilidad...",
        validating: "Validando fechas y disponibilidad...",
        noValidate: "No se pudo validar la disponibilidad.",
        noStock: "No hay disponibilidad para esas fechas. Escríbenos por WhatsApp para sugerirte alternativas.",
        available: (domes: number, total: number, nights: number) =>
          `Disponible: ${domes} domo(s). Estimado: S/ ${total} por ${nights} noche(s).`,
        leadFail: "Disponibilidad encontrada, pero no pudimos registrar la pre-reserva. Intenta otra vez.",
        generic: "No pudimos procesar tu solicitud ahora. Intenta nuevamente en unos minutos.",
        submit: "Consultar disponibilidad y enviar por WhatsApp",
        waIntro: "Hola Colca Star Domes, quiero realizar una pre-reserva.",
        waName: "Nombre",
        waGuests: "Huéspedes",
        waConfirmed: "Disponibilidad confirmada",
        waEstimate: "Estimado total",
        waCode: "Código interno de pre-reserva",
        waExtra: "Mensaje adicional",
      };
  const form = document.querySelector("#prebooking-form");

  const getElement = (selector: string) => document.querySelector(selector);

  const setStatus = (message: string, type: "info" | "success" | "error" = "info") => {
    const statusElement = document.querySelector("#availability-status");
    if (!(statusElement instanceof HTMLElement)) {
      return;
    }

    statusElement.classList.remove(
      "hidden",
      "border-emerald-500/40",
      "bg-emerald-500/10",
      "text-emerald-100",
      "border-rose-500/40",
      "bg-rose-500/10",
      "text-rose-100",
      "border-slate-600",
      "bg-slate-900/70",
      "text-slate-200"
    );

    if (type === "success") {
      statusElement.classList.add("border-emerald-500/40", "bg-emerald-500/10", "text-emerald-100");
    } else if (type === "error") {
      statusElement.classList.add("border-rose-500/40", "bg-rose-500/10", "text-rose-100");
    } else {
      statusElement.classList.add("border-slate-600", "bg-slate-900/70", "text-slate-200");
    }

    statusElement.textContent = message;
  };

  if (form instanceof HTMLFormElement) {
    const calendarButton = document.querySelector("#date-range-button");
    const calendarLabel = document.querySelector("#date-range-label");
    const calendarPopover = document.querySelector("#calendar-popover");
    const calendarGrid = document.querySelector("#calendar-grid");
    const calPrev = document.querySelector("#cal-prev");
    const calNext = document.querySelector("#cal-next");
    const calClose = document.querySelector("#cal-close");

    const checkinInput = document.querySelector("#checkin-date");
    const checkoutInput = document.querySelector("#checkout-date");

    const toIso = (d: Date) => d.toISOString().slice(0, 10);
    const fromIso = (raw: string) => new Date(`${raw}T00:00:00Z`);
    const isSameOrAfter = (a: string, b: string) => a >= b;
    const addDays = (raw: string, days: number) => {
      const d = fromIso(raw);
      d.setUTCDate(d.getUTCDate() + days);
      return toIso(d);
    };

    let view = new Date();
    view.setUTCDate(1);
    let availabilityCache = new Map<string, number>(); // date -> availableDomes

    const fetchMonth = async (year: number, month: number) => {
      const response = await fetch(`/api/calendar?year=${year}&month=${month}`);
      const data = await response.json().catch(() => null);
      if (!response.ok || !data?.ok) {
        return [];
      }
      return data.days as Array<{ date: string; availableDomes: number }>;
    };

    const ensureAvailability = async (base: Date) => {
      availabilityCache.clear();
      const year1 = base.getUTCFullYear();
      const month1 = base.getUTCMonth() + 1;
      const next = new Date(Date.UTC(year1, base.getUTCMonth() + 1, 1));
      const year2 = next.getUTCFullYear();
      const month2 = next.getUTCMonth() + 1;

      const [days1, days2] = await Promise.all([fetchMonth(year1, month1), fetchMonth(year2, month2)]);
      for (const d of [...days1, ...days2]) {
        availabilityCache.set(d.date, d.availableDomes);
      }
    };

    const monthName = (d: Date) =>
      d.toLocaleString(i18n.locale, { month: "long", year: "numeric", timeZone: "UTC" });

    const renderMonth = (base: Date) => {
      const year = base.getUTCFullYear();
      const month = base.getUTCMonth();
      const first = new Date(Date.UTC(year, month, 1));
      const startDay = (first.getUTCDay() + 6) % 7; // Monday=0
      const daysInMonth = new Date(Date.UTC(year, month + 1, 0)).getUTCDate();

      const checkin = (checkinInput as HTMLInputElement | null)?.value ?? "";
      const checkout = (checkoutInput as HTMLInputElement | null)?.value ?? "";

      let html = `<div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-4">
  <p class="text-sm font-medium text-slate-200">${monthName(first)}</p>
  <div class="mt-3 grid grid-cols-7 gap-1 text-[11px] text-slate-400">
    <span>${i18n.weekdays[0]}</span><span>${i18n.weekdays[1]}</span><span>${i18n.weekdays[2]}</span><span>${i18n.weekdays[3]}</span><span>${i18n.weekdays[4]}</span><span>${i18n.weekdays[5]}</span><span>${i18n.weekdays[6]}</span>
  </div>
  <div class="mt-2 grid grid-cols-7 gap-1">`;

      for (let i = 0; i < startDay; i++) {
        html += `<span class="h-10"></span>`;
      }

      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(Date.UTC(year, month, day));
        const iso = toIso(date);
        const available = availabilityCache.get(iso);
        const isSoldOut = typeof available === "number" && available <= 0;
        const isSelected =
          (checkin && iso === checkin) ||
          (checkout && iso === checkout) ||
          (checkin && checkout && iso > checkin && iso < checkout);

        const baseClass =
          "h-10 w-full rounded-xl border text-xs transition focus:outline-none focus:ring-2 focus:ring-gold/60";
        const stateClass = isSoldOut
          ? "border-rose-500/40 bg-rose-500/10 text-rose-100 opacity-60 cursor-not-allowed"
          : "border-slate-700 bg-slate-950/50 text-slate-100 hover:bg-slate-900/70";
        const selectedClass = isSelected ? " ring-2 ring-gold/60 border-gold" : "";

        html += `<button type="button" class="${baseClass} ${stateClass}${selectedClass}" data-cal-day="${iso}" ${
          isSoldOut ? "disabled" : ""
        }>
  <span class="block leading-4">${day}</span>
  <span class="block text-[10px] text-slate-300">${typeof available === "number" ? available : "-"}</span>
</button>`;
      }

      html += `</div></div></div>`;
      return html;
    };

    const renderCalendar = async () => {
      if (!(calendarGrid instanceof HTMLElement)) return;
      await ensureAvailability(view);
      const next = new Date(Date.UTC(view.getUTCFullYear(), view.getUTCMonth() + 1, 1));
      calendarGrid.innerHTML = renderMonth(view) + renderMonth(next);
    };

    const updateLabel = () => {
      if (!(calendarLabel instanceof HTMLElement)) return;
      const checkin = (checkinInput as HTMLInputElement | null)?.value ?? "";
      const checkout = (checkoutInput as HTMLInputElement | null)?.value ?? "";
      calendarLabel.textContent = checkin && checkout ? `${checkin} → ${checkout}` : i18n.selectRange;
    };

    if (calendarButton instanceof HTMLButtonElement && calendarPopover instanceof HTMLElement) {
      calendarButton.addEventListener("click", async () => {
        const isHidden = calendarPopover.classList.contains("hidden");
        calendarPopover.classList.toggle("hidden", !isHidden);
        if (isHidden) {
          await renderCalendar();
        }
      });
    }

    if (calClose instanceof HTMLButtonElement && calendarPopover instanceof HTMLElement) {
      calClose.addEventListener("click", () => calendarPopover.classList.add("hidden"));
    }

    if (calPrev instanceof HTMLButtonElement) {
      calPrev.addEventListener("click", async () => {
        view = new Date(Date.UTC(view.getUTCFullYear(), view.getUTCMonth() - 1, 1));
        await renderCalendar();
      });
    }

    if (calNext instanceof HTMLButtonElement) {
      calNext.addEventListener("click", async () => {
        view = new Date(Date.UTC(view.getUTCFullYear(), view.getUTCMonth() + 1, 1));
        await renderCalendar();
      });
    }

    document.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const dayButton = target.closest("[data-cal-day]");
      if (!(dayButton instanceof HTMLButtonElement)) return;

      const date = dayButton.getAttribute("data-cal-day") ?? "";
      if (!date) return;

      const checkinEl = checkinInput as HTMLInputElement | null;
      const checkoutEl = checkoutInput as HTMLInputElement | null;
      if (!checkinEl || !checkoutEl) return;

      const currentIn = checkinEl.value;
      const currentOut = checkoutEl.value;

      // Start new range if empty or completed
      if (!currentIn || (currentIn && currentOut)) {
        checkinEl.value = date;
        checkoutEl.value = "";
        updateLabel();
        await renderCalendar();
        return;
      }

      // Set checkout (must be after checkin)
      if (currentIn && !currentOut) {
        if (!isSameOrAfter(date, addDays(currentIn, 1))) {
          // If user clicks same/previous date, restart range
          checkinEl.value = date;
          checkoutEl.value = "";
          updateLabel();
          await renderCalendar();
          return;
        }

        checkoutEl.value = date;
        updateLabel();
        await renderCalendar();
      }
    });

    updateLabel();

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const submitButton = form.querySelector('button[type="submit"]');
      const name = (getElement("#guest-name") as HTMLInputElement | null)?.value.trim();
      const checkin = (getElement("#checkin-date") as HTMLInputElement | null)?.value;
      const checkout = (getElement("#checkout-date") as HTMLInputElement | null)?.value;
      const guests = (getElement("#guests") as HTMLSelectElement | null)?.value;
      const extra = (getElement("#extra-message") as HTMLTextAreaElement | null)?.value.trim();

      if (!name || !checkin || !checkout || !guests) {
        setStatus(i18n.fill, "error");
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = i18n.checking;
      }

      setStatus(i18n.validating, "info");

      try {
        const availabilityResponse = await fetch("/api/availability", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            checkInRaw: checkin,
            checkOutRaw: checkout,
            guests: Number(guests),
          }),
        });

        const availabilityData = await availabilityResponse.json();

        if (!availabilityResponse.ok || !availabilityData.ok) {
          setStatus(availabilityData.message ?? i18n.noValidate, "error");
          return;
        }

        if (!availabilityData.available) {
          setStatus(i18n.noStock, "error");
          return;
        }

        setStatus(i18n.available(availabilityData.availableDomes, availabilityData.totalEstimate, availabilityData.nights), "success");

        const leadResponse = await fetch("/api/prebook", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            fullName: name,
            checkInRaw: checkin,
            checkOutRaw: checkout,
            guests: Number(guests),
            notes: extra ?? "",
            availabilitySnapshot: {
              availableDomes: availabilityData.availableDomes,
              nights: availabilityData.nights,
              totalEstimate: availabilityData.totalEstimate,
              nightlyRate: availabilityData.nightlyRate,
            },
          }),
        });

        const leadData = await leadResponse.json();
        if (!leadResponse.ok || !leadData.ok) {
          setStatus(i18n.leadFail, "error");
          return;
        }

        const messageLines = [
          i18n.waIntro,
          `${i18n.waName}: ${name}`,
          `Check-in: ${checkin}`,
          `Check-out: ${checkout}`,
          `${i18n.waGuests}: ${guests}`,
          `${i18n.waConfirmed}: ${availabilityData.availableDomes} domo(s)`,
          `${i18n.waEstimate}: S/ ${availabilityData.totalEstimate}`,
          `${i18n.waCode}: ${leadData.leadId}`,
        ];

        if (extra) {
          messageLines.push(`${i18n.waExtra}: ${extra}`);
        }

        const encodedMessage = encodeURIComponent(messageLines.join("\n"));
        const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;
        window.open(whatsappUrl, "_blank", "noopener,noreferrer");
      } catch {
        setStatus(i18n.generic, "error");
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = i18n.submit;
        }
      }
    });
  }
</script>

