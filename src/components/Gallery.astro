---
import { getLangFromPath, t } from "../i18n";
const lang = getLangFromPath(Astro.url.pathname);
const tr = t(lang);

const images = [
  {
    src: "https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=1400&q=80",
    alt: "Colca Canyon landscape in Arequipa, Peru",
    tall: true,
  },
  {
    src: "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1400&q=80",
    alt: "Andean valley near Colca in Peru",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1454789548928-9efd52dc4031?auto=format&fit=crop&w=1400&q=80",
    alt: "Milky Way over the Peruvian Andes",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1400&q=80",
    alt: "Night sky in Arequipa region",
    tall: true,
  },
  {
    src: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=1400&q=80",
    alt: "Sunrise at Colca Canyon, Peru",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?auto=format&fit=crop&w=1400&q=80",
    alt: "Stargazing night in Peruvian mountains",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1400&q=80",
    alt: "Colca Valley landscape in Arequipa",
    tall: true,
  },
  {
    src: "https://images.unsplash.com/photo-1444703686981-a3abbc4d4fe3?auto=format&fit=crop&w=1400&q=80",
    alt: "Stars above Andes in Peru",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1416331108676-a22ccb276e35?auto=format&fit=crop&w=1400&q=80",
    alt: "Mountain view at Colca Canyon",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1400&q=80",
    alt: "Milky Way view in Arequipa Andes",
    tall: true,
  },
  {
    src: "https://images.unsplash.com/photo-1465101046530-73398c7f28ca?auto=format&fit=crop&w=1400&q=80",
    alt: "Nature and valley around Colca, Peru",
    tall: false,
  },
  {
    src: "https://images.unsplash.com/photo-1472396961693-142e6e269027?auto=format&fit=crop&w=1400&q=80",
    alt: "Night sky over canyon in Peru",
    tall: false,
  },
];
---

<section id="gallery" class="mx-auto w-full max-w-6xl scroll-mt-28 px-4 py-16 sm:px-6 md:py-24 lg:px-8">
  <div class="mb-10 text-center">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-gold sm:text-sm">{tr.gallery.eyebrow}</p>
    <h2 class="mt-3 text-2xl font-semibold text-sillar sm:text-3xl">{tr.gallery.title}</h2>
    <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-slate-300 sm:text-base">
      {tr.gallery.body}
    </p>
  </div>

  <div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:auto-rows-[180px]">
    {
      images.map((image) => (
        <figure
          class={`overflow-hidden rounded-2xl border border-slate-800 bg-slate-800/70 ${
            image.tall ? "md:row-span-2" : "md:row-span-1"
          }`}
        >
          <img
            src={image.src}
            alt={image.alt}
            loading="lazy"
            decoding="async"
            onerror="this.onerror=null;this.src='https://placehold.co/1400x1000/0f172a/f8fafc?text=Colca+Arequipa+Peru';"
            class="h-full w-full object-cover transition duration-500 hover:scale-[1.03]"
          />
        </figure>
      ))
    }
  </div>
</section>

