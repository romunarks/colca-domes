---
import { getLangFromPath, t } from "../i18n";
const lang = getLangFromPath(Astro.url.pathname);
const tr = t(lang);

const images = [
  {
    src: "https://images.pexels.com/photos/998641/pexels-photo-998641.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[0],
    tall: true,
  },
  {
    src: "https://images.pexels.com/photos/1169754/pexels-photo-1169754.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[1],
    tall: false,
  },
  {
    src: "https://images.pexels.com/photos/3037990/pexels-photo-3037990.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[2],
    tall: false,
  },
  {
    src: "https://images.pexels.com/photos/2503503/pexels-photo-2503503.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[3],
    tall: true,
  },
  {
    src: "https://images.pexels.com/photos/730241/pexels-photo-730241.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[4],
    tall: false,
  },
  {
    src: "https://images.pexels.com/photos/1274260/pexels-photo-1274260.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[5],
    tall: false,
  },
  {
    src: "https://images.pexels.com/photos/3408744/pexels-photo-3408744.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[0],
    tall: true,
  },
  {
    src: "https://images.pexels.com/photos/1624438/pexels-photo-1624438.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[2],
    tall: false,
  },
  {
    src: "https://images.pexels.com/photos/2114014/pexels-photo-2114014.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[4],
    tall: false,
  },
  {
    src: "https://images.pexels.com/photos/2387873/pexels-photo-2387873.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[3],
    tall: true,
  },
  {
    src: "https://images.pexels.com/photos/1761279/pexels-photo-1761279.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[1],
    tall: false,
  },
  {
    src: "https://images.pexels.com/photos/2728255/pexels-photo-2728255.jpeg?auto=compress&cs=tinysrgb&w=1200",
    alt: tr.gallery.alts[5],
    tall: false,
  },
];
---

<section id="gallery" class="mx-auto w-full max-w-6xl scroll-mt-28 px-4 py-16 sm:px-6 md:py-24 lg:px-8">
  <div class="mb-10 text-center">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-gold sm:text-sm">{tr.gallery.eyebrow}</p>
    <h2 class="mt-3 text-2xl font-semibold text-sillar sm:text-3xl">{tr.gallery.title}</h2>
    <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-slate-300 sm:text-base">
      {tr.gallery.body}
    </p>
  </div>

  <div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:auto-rows-[180px]">
    {
      images.map((image) => (
        <figure
          class={`overflow-hidden rounded-2xl border border-slate-800 bg-slate-800/70 ${
            image.tall ? "md:row-span-2" : "md:row-span-1"
          }`}
        >
          <img
            src={image.src}
            alt={image.alt}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition duration-500 hover:scale-[1.03]"
          />
        </figure>
      ))
    }
  </div>
</section>

