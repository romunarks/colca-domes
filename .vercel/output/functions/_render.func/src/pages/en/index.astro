---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import Features from "../../components/Features.astro";
import Packages from "../../components/Packages.astro";
import Gallery from "../../components/Gallery.astro";
import PreBooking from "../../components/PreBooking.astro";
import Faq from "../../components/Faq.astro";
import Footer from "../../components/Footer.astro";
import StickyFooter from "../../components/StickyFooter.astro";
import { t } from "../../i18n";

const tr = t("en");
---

<Layout title={tr.page.homeTitle} description={tr.page.homeDesc}>
  <Header />
  <Hero />
  <Features />
  <Packages />
  <Gallery />
  <PreBooking />
  <Faq />
  <Footer />
  <StickyFooter />
</Layout>

