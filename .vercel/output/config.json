{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/leads/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/domes/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/leads/status/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/reservations/assign/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/reservations/cancel/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/reservations/delete/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/reservations/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/availability/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/calendar/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/prebook/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}